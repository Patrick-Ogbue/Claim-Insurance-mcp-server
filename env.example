# ═══════════════════════════════════════════════════════════════════════════════
# Claim Pilot — MCP server (FastMCP + HTTP tools)
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env in this directory:  cp env.example .env
#
# WARNING: Never commit .env to version control!
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# AWS (optional — for future integrations from tools)
# ─────────────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# GitHub — PAT for private git deps (see claim-pilot-backend/env.example)
# ─────────────────────────────────────────────────────────────────────────────
# GITHUB_TOKEN=
